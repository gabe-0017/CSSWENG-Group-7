<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — The Caterer & Co</title>
  <link rel="stylesheet" href="/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── NAVBAR ── -->
  <nav class="navbar">
    <div class="nav-brand">
      <span class="brand-main">The Caterer & Co</span>
      <span class="brand-sub">by Amosco Event Catering Services</span>
    </div>
    <ul class="nav-links">
      <li><a href="/#packages">View Packages</a></li>
      <li><a href="/#portfolio">View Portfolio</a></li>
      <li><a href="/#contact">Contact Us</a></li>
    </ul>
  </nav>

  <!-- ── ADMIN LOGIN ── -->
  <div class="booking-page">
    <div class="booking-container" style="max-width: 480px;">

      <h2>Admin Login</h2>
      <p class="booking-subtitle">Sign in to manage your catering website.</p>

      <% if (error) { %>
        <p class="admin-login-error"><%= error %></p>
      <% } %>

      <form action="/admin/login" method="POST">

        <div class="form-group">
          <label>Username</label>
          <input type="email" name="email" required />
        </div>

        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required />
        </div>

        <button class="book-btn" type="submit">Sign In</button>

      </form>

    </div>
  </div>

</body>
</html>