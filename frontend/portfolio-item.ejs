<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= item.portfolio_title %> — The Caterer & Co</title>
  <link rel="stylesheet" href="/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── NAVBAR ── -->
  <nav class="navbar">
    <div class="nav-brand">
      <span class="brand-main">The Caterer & Co</span>
      <span class="brand-sub">by Amosco Event Catering Services</span>
    </div>
    <ul class="nav-links">
      <li><a href="/#packages">View Packages</a></li>
      <li><a href="/#portfolio">View Portfolio</a></li>
      <li><a href="/#contact">Contact Us</a></li>
    </ul>
  </nav>

  <!-- ── PORTFOLIO DETAIL ── -->
  <section class="portfolio-detail">
    <div class="portfolio-detail-inner">

      <a href="/#portfolio" class="btn btn-secondary portfolio-back-btn">&#8592; Back to Portfolio</a>

      <h1 class="portfolio-detail-title"><%= item.portfolio_title %></h1>
      <p class="portfolio-detail-desc"><%= item.portfolio_desc %></p>

      <% if (images && images.length > 0) { %>
        <div class="portfolio-detail-gallery">
          <% images.forEach(function(img) { %>
            <img src="<%= img.image_url %>" alt="<%= item.portfolio_title %>" />
          <% }) %>
        </div>
      <% } else { %>
        <p class="portfolio-detail-empty">No images have been added to this portfolio item yet.</p>
      <% } %>

    </div>
  </section>

</body>
</html>
